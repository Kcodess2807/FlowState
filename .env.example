# Copy this file to .env and adjust values for your environment.

# --- App ---
PROJECT_NAME=FlowState
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database ---
# When running the backend via docker-compose, POSTGRES_HOST must be the
# compose service name ("db"). For running the app directly on your host
# against the compose Postgres, use "localhost".
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=flowstate
POSTGRES_PASSWORD=flowstate
POSTGRES_DB=flowstate

# --- Auth / JWT ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-every-real-environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Evaluation (OpenRouter) ---
# Leave the key empty to use the heuristic fallback grader. Set it for real
# AI grading. Pick a current model slug from https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EVAL_MODEL=anthropic/claude-3.5-sonnet
EVAL_PASS_THRESHOLD=70
